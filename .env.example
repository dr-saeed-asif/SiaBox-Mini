# ===========================================
# SiaBox Mini — Environment Variables
# Copy this file to .env.local and fill in values
# ===========================================

# App settings
APP_NAME="SiaBox Mini"
APP_URL="http://localhost:3000"

# Database (SQLite — no extra server needed)
DATABASE_URL="file:./dev.db"

# Storage provider: "local" or "sia"
STORAGE_PROVIDER="local"

# --- Local storage settings (used when STORAGE_PROVIDER=local) ---
LOCAL_STORAGE_PATH="./storage/uploads"

# --- Sia S3 settings (used when STORAGE_PROVIDER=sia) ---
# renterd must be running with S3 API enabled
SIA_S3_ENDPOINT="http://127.0.0.1:8080"
SIA_S3_REGION="us-east-1"
SIA_S3_ACCESS_KEY=""
SIA_S3_SECRET_KEY=""
SIA_S3_BUCKET="siabox-mini"
SIA_S3_FORCE_PATH_STYLE="true"

# Upload limits
MAX_UPLOAD_SIZE_MB="50"
ALLOWED_FILE_TYPES="pdf,docx,xlsx,csv,zip,png,jpg,jpeg,mp3,mp4"
